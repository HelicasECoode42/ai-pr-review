{
  "name": "ai-pr-review",
  "displayName": "AI PR Review",
  "description": "Auto-load AI PR Review results from GitHub into VS Code Problems panel — zero config, uses gh CLI",
  "version": "0.2.0",
  "publisher": "ai-pr-review-team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelicasECoode42/ai-pr-review"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-pr-review.refresh",
        "title": "AI PR Review: Refresh"
      },
      {
        "command": "ai-pr-review.loadReport",
        "title": "AI PR Review: Load Report File"
      },
      {
        "command": "ai-pr-review.clearDiagnostics",
        "title": "AI PR Review: Clear Diagnostics"
      },
      {
        "command": "ai-pr-review.openPanel",
        "title": "AI PR Review: Open Review Panel"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.0"
  }
}
